{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000
      }
    },
    "controlUi": {
      "allowInsecureAuth": false,
      "allowedOrigins": [
        "https://kurt.exploraria.cc"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": false
    },
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "agents": {
    "defaults": {
      "timeoutSeconds": 600,
      "workspace": "/root/.openclaw/workspace",
      "model": {
        "primary": "google/gemini-3.1-pro-preview"
      },
      "models": {
        "google/gemini-3-flash-preview": {},
        "google/gemini-3.1-pro-preview": {}
      },
      "heartbeat": {
        "every": "30m"
      },
      "thinkingDefault": "high"
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "provider": "tavily"
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "webchat": [
          "*"
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "google": {
        "enabled": true
      },
      "tavily": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": "${TAVILY_API_KEY}"
          }
        }
      },
      "browser": {
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },
  "skills": {
    "entries": {
      "goplaces": {
        "apiKey": "${GOOGLE_PLACES_API_KEY}",
        "enabled": false
      },
      "gog": {
        "enabled": true
      },
