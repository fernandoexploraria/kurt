    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.5.20",
    "lastTouchedAt": "2026-06-01T02:25:58.802Z"
  },
  "channels": {
    "telegram": {
      "accounts": {
        "default": {
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "ackReaction": "🤟",
          "reactionLevel": "extensive"
        }
      },
      "enabled": true
    }
  },
  "commands": {
    "ownerAllowFrom": [
      "telegram:${TELEGRAM_ALLOWED_USER_1}"
    ]
  },
  "mcp": {
    "servers": {
      "RapidAPI Hub - TradingView Data": {
        "command": "sh",
        "args": [
          "-c",
          "npx mcp-remote https://mcp.rapidapi.com --header 'x-api-host: tradingview-data1.p.rapidapi.com' --header \"x-api-key: ${RAPIDAPI_KEY}\""
        ]
      },
      "Tavily Search": {
        "command": "sh",
        "args": [
          "-c",
          "npx mcp-remote \"https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}\""
        ]
      }
    }
  },
  "messages": {
    "groupChat": {
      "visibleReplies": "automatic"
    }
  },
  "browser": {
    "enabled": true,
    "noSandbox": true
  }
